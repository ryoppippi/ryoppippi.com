{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["vite/client"],
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"strictNullChecks": true,
		"declaration": true,
		"outDir": "dist",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"plugins": [
			{ "transform": "typia/lib/transform" }
		]
	},
	"include": ["./src/lib/*.ts"]
}
