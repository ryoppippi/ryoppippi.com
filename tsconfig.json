{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"resolveJsonModule": true,
		"types": [
			"@total-typescript/ts-reset",
			"vitest/globals",
			"vitest/importMeta"
		],
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"plugins": [
			{
				"name": "typescript-svelte-plugin"
			}
		]
	}
}
