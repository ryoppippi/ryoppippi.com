{
	"name": "ryoppippi.com",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"runtime": [
			{
				"name": "node",
				"version": "^24.14.0",
				"onFail": "download"
			}
		]
	},
	"scripts": {
		"build": "vite build",
		"postbuild": "svelte-sitemap --domain https://ryoppippi.com -o ./build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "wrangler deploy",
		"deploy:non-production": "wrangler versions upload",
		"dev": "vite dev",
		"format": "nr lint --fix",
		"preinstall": "only-allow pnpm",
		"lint": "eslint --cache .",
		"new": "./scripts/new-post.js",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
		"typos": "typos --force-exclude ./src/contents/**/*.md"
	},
	"dependencies": {},
	"devDependencies": {
		"@antfu/ni": "^30.1.0",
		"@clack/prompts": "^1.3.0",
		"@core/iterutil": "jsr:^0.9.0",
		"@core/pipe": "jsr:^0.4.0",
		"@iconify/json": "^2.2.470",
		"@iconify/tailwind4": "^1.2.3",
		"@ryoppippi/eslint-config": "^0.4.0",
		"@ryoppippi/str-fns": "jsr:^0.1.2",
		"@ryoppippi/vite-plugin-cloudflare-redirect": "^1.1.3",
		"@shikijs/twoslash": "^4.0.2",
		"@std/collections": "jsr:^1.1.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/mcp": "^0.1.22",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/diacritics": "^1.3.3",
		"@types/dom-view-transitions": "^1.0.6",
		"@types/fs-extra": "^11.0.4",
		"@types/markdown-it-link-attributes": "^3.0.5",
		"@types/node": "^24.12.3",
		"arktype": "^2.2.0",
		"date-fns": "^4.1.0",
		"diacritics": "^1.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-svelte": "^3.17.1",
		"fast-sort": "^3.4.1",
		"feed": "^5.2.1",
		"fs-extra": "^11.3.5",
		"gray-matter-es": "0.2.1",
		"lefthook": "^2.1.6",
		"magic-string": "^0.30.21",
		"markdown-exit": "1.0.0-beta.9",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-budoux": "^1.0.6",
		"markdown-it-collapsible": "^2.0.2",
		"markdown-it-github-alerts": "^1.0.1",
		"markdown-it-image-figures": "^2.1.1",
		"markdown-it-link-attributes": "^4.0.1",
		"markdown-it-link-preview": "^1.1.4",
		"markdown-it-magic-link": "^0.1.4",
		"markdown-it-mdc": "^0.2.12",
		"only-allow": "^1.2.2",
		"open-editor": "^6.0.0",
		"reading-time": "^1.5.0",
		"rss-parser": "^3.13.0",
		"shiki": "^4.0.2",
		"sort-package-json": "^3.6.1",
		"std-env": "^4.1.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-fancy-darkmode": "^1.1.4",
		"svelte-meta-tags": "^4.7.0",
		"svelte-preprocess-import-assets": "^1.1.0",
		"svelte-sitemap": "^3.1.0",
		"sveltekit-embed": "^0.0.22",
		"sveltweet": "^0.5.1",
		"tailwindcss": "^4.3.0",
		"tinyglobby": "^0.2.16",
		"type-fest": "^5.6.0",
		"typescript-svelte-plugin": "^0.3.52",
		"ufo": "^1.6.4",
		"vite": "^8.0.11",
		"vite-plugin-favicons": "^0.1.7"
	}
}
