{
	"name": "ryoppippi.com",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vp run site-build",
		"check": "vp check",
		"deploy": "wrangler deploy",
		"deploy:non-production": "wrangler versions upload",
		"dev": "vp dev",
		"format": "vp check --fix",
		"preinstall": "only-allow pnpm",
		"lint": "vp lint",
		"new": "vp run @ryoppippi/content#new",
		"preview": "vp preview",
		"test": "vp test --run",
		"typos": "typos --force-exclude --exclude '**/*.json' src/contents packages/content/src/blog packages/content/src/showcase"
	},
	"devDependencies": {
		"@fontsource/dm-mono": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/roboto-condensed": "^5.2.8",
		"@iconify/json": "^2.2.470",
		"@iconify/tailwind4": "^1.2.3",
		"@ox-content/vite-plugin": "2.72.0",
		"@ox-content/vite-plugin-svelte": "2.72.0",
		"@ryoppippi/content": "workspace:*",
		"@ryoppippi/vite-plugin-cloudflare-redirect": "^1.1.3",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24.12.3",
		"bun": "1.3.14",
		"feed": "^5.2.1",
		"fs-fixture": "^2.14.0",
		"lefthook": "^2.1.6",
		"only-allow": "^1.2.2",
		"parse5": "^7.3.0",
		"rss-parser": "^3.13.0",
		"svelte": "^5.56.2",
		"tailwindcss": "^4.3.0",
		"tinyglobby": "^0.2.16",
		"vite": "npm:@voidzero-dev/vite-plus-core@^0.2.1",
		"vite-plus": "0.2.1"
	},
	"devEngines": {
		"runtime": [
			{
				"name": "node",
				"version": "^24.14.0",
				"onFail": "download"
			}
		]
	},
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
