{
	"name": "ryoppippi.com",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
	"engines": {
		"runtime": [
			{
				"name": "node",
				"version": "^24.14.0",
				"onFail": "download"
			}
		]
	},
	"scripts": {
		"build": "vite build",
		"postbuild": "node scripts/generate-site.ts",
		"check": "tsc --noEmit",
		"check:watch": "tsc --noEmit --watch",
		"deploy": "wrangler deploy",
		"deploy:non-production": "wrangler versions upload",
		"dev": "pnpm build && vite preview",
		"format": "nr lint --fix",
		"preinstall": "only-allow pnpm",
		"lint": "eslint --cache .",
		"new": "./scripts/new-post.ts",
		"preview": "vite preview",
		"test": "vitest run",
		"typos": "typos --force-exclude ./src/contents/**/*.md"
	},
	"dependencies": {},
	"devDependencies": {
		"@antfu/ni": "^30.1.0",
		"@clack/prompts": "^1.3.0",
		"@fontsource/dm-mono": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/roboto-condensed": "^5.2.8",
		"@iconify/json": "^2.2.470",
		"@iconify/tailwind4": "^1.2.3",
		"@ox-content/napi": "^2.44.0",
		"@ryoppippi/eslint-config": "^0.4.0",
		"@shikijs/twoslash": "^4.0.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/diacritics": "^1.3.3",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^24.12.3",
		"budoux": "^0.8.4",
		"date-fns": "^4.1.0",
		"diacritics": "^1.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-svelte": "^3.19.0",
		"feed": "^5.2.1",
		"fs-extra": "^11.3.5",
		"gray-matter-es": "0.2.1",
		"lefthook": "^2.1.6",
		"only-allow": "^1.2.2",
		"open-editor": "^6.0.0",
		"reading-time": "^1.5.0",
		"rss-parser": "^3.13.0",
		"shiki": "^4.0.2",
		"sort-package-json": "^3.6.1",
		"svelte": "^5.56.2",
		"svelte-fancy-darkmode": "^1.1.4",
		"tailwindcss": "^4.3.0",
		"tinyglobby": "^0.2.16",
		"typescript": "^5.9.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.8"
	}
}
